job "{{.AppName}}" {
  datacenters = ["dc1"]
  type        = "service"

  group "{{.AppName}}" {
    count = 1

    network {
      port "http" {
        to = 8080
      }
    }

    task "{{.AppName}}" {
      driver = "docker"

      config {
        image = "{{.AppName}}:latest"
        ports = ["http"]
      }

      resources {
        cpu    = 256
        memory = 256
      }

      service {
        name = "{{.AppName}}"
        port = "http"

        check {
          type     = "http"
          path     = "/health"
          interval = "10s"
          timeout  = "2s"
        }
      }
    }
  }
}
