package redis

import (
	"context"
	"fmt"

	"github.com/paularlott/logger"
	goredis "github.com/redis/go-redis/v9"

	"{{.ModulePath}}/internal/resolve"
)

type Client struct {
	rdb *goredis.Client
	log logger.Logger
}

func NewClient(log logger.Logger, host string, port int, password string, db int) (*Client, error) {
	resolved, err := resolve.LookupSRV(host, uint16(port))
	if err != nil {
		return nil, fmt.Errorf("resolving redis host: %w", err)
	}

	rdb := goredis.NewClient(&goredis.Options{
		Addr:     fmt.Sprintf("%s:%d", resolved.Host, resolved.Port),
		Password: password,
		DB:       db,
	})

	ctx := context.Background()
	if err := rdb.Ping(ctx).Err(); err != nil {
		return nil, fmt.Errorf("connecting to redis: %w", err)
	}

	log.Info("connected to redis", "host", resolved.Host, "port", resolved.Port)
	return &Client{rdb: rdb, log: log}, nil
}

func (c *Client) Close() error {
	return c.rdb.Close()
}
