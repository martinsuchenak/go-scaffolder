package cmd

import (
	"context"
	"fmt"
	"os"

	"github.com/paularlott/cli"
	logslog "github.com/paularlott/logger/slog"
)

func init() {
	Register({{toCamel .ResourceName}}Cmd())
}

func {{toCamel .ResourceName}}Cmd() *cli.Command {
	return &cli.Command{
		Name:  "{{toKebab .ResourceName}}",
		Usage: "{{toPascal .ResourceName}} command for {{.AppName}}",
		Run: func(ctx context.Context, cmd *cli.Command) error {
			log := logslog.New(logslog.Config{
				Level:  cmd.GetString("log-level"),
				Format: cmd.GetString("log-format"),
				Writer: os.Stdout,
			})
			log.Info("running {{toKebab .ResourceName}} command")
			fmt.Println("{{toPascal .ResourceName}} command executed")
			return nil
		},
	}
}
