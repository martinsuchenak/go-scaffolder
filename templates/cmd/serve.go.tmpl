package cmd

import (
	"context"
{{- if .Features.API}}
	"fmt"
	"net/http"
{{- end}}
	"os"

	"github.com/paularlott/cli"
	logslog "github.com/paularlott/logger/slog"
{{- if .Features.API}}

	"{{.ModulePath}}/cmd/routes"
{{- end}}
{{- if .Features.MCP}}

	mcpserver "{{.ModulePath}}/cmd/mcp"
{{- end}}
)

func serveCmd() *cli.Command {
	return &cli.Command{
		Name:  "serve",
		Usage: "Start the {{.AppName}} service",
{{- if .Features.API}}
		Flags: []cli.Flag{
			&cli.StringFlag{
				Name:         "server-host",
				DefaultValue: "0.0.0.0",
				Usage:        "Server listen host",
				ConfigPath:   []string{"server.host"},
				EnvVars:      []string{"SERVER_HOST"},
			},
			&cli.IntFlag{
				Name:         "server-port",
				DefaultValue: 8080,
				Usage:        "Server listen port",
				ConfigPath:   []string{"server.port"},
				EnvVars:      []string{"SERVER_PORT"},
			},
		},
{{- end}}
		Run: func(ctx context.Context, cmd *cli.Command) error {
			log := logslog.New(logslog.Config{
				Level:  cmd.GetString("log-level"),
				Format: cmd.GetString("log-format"),
				Writer: os.Stdout,
			})
			log.Info("starting {{.AppName}} service")
{{- if .Features.MCP}}

			mcpserver.StartMCPServer(log)
{{- end}}
{{- if .Features.API}}

			mux := http.NewServeMux()
			routes.RegisterRoutes(mux)

			addr := fmt.Sprintf("%s:%d", cmd.GetString("server-host"), cmd.GetInt("server-port"))
			log.Info("starting HTTP server", "addr", addr)
			return http.ListenAndServe(addr, mux)
{{- else}}

			log.Info("{{.AppName}} is running")
			select {}
{{- end}}
		},
	}
}
