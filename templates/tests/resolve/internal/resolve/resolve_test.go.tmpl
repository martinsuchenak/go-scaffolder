package resolve

import (
	"testing"

	"github.com/paularlott/logger"
)

func TestLookupSRVFallback(t *testing.T) {
	result, err := LookupSRV("192.0.2.1", 5432)
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	if result.Host != "192.0.2.1" {
		t.Errorf("expected host '192.0.2.1', got %q", result.Host)
	}
	if result.Port != 5432 {
		t.Errorf("expected port 5432, got %d", result.Port)
	}
}

func TestLookupAllSRVFallback(t *testing.T) {
	results, err := LookupAllSRV("192.0.2.1", 8080)
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	if len(results) == 0 {
		t.Fatal("expected at least one result")
	}
	if results[0].Host != "192.0.2.1" {
		t.Errorf("expected host '192.0.2.1', got %q", results[0].Host)
	}
}

func TestResolverWithCache(t *testing.T) {
	r := NewResolver(logger.NewNullLogger())

	result1, err := r.LookupSRV("192.0.2.1", 5432)
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}

	result2, err := r.LookupSRV("192.0.2.1", 5432)
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}

	if result1.Host != result2.Host || result1.Port != result2.Port {
		t.Error("cached result should match original")
	}

	r.ClearCache()
}

func TestResolveSRVAddress(t *testing.T) {
	r := NewResolver(logger.NewNullLogger())
	addr, err := r.ResolveSRVAddress("192.0.2.1", 6379)
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	if addr != "192.0.2.1:6379" {
		t.Errorf("expected '192.0.2.1:6379', got %q", addr)
	}
}

func TestResolveSRVHttpNoPrefix(t *testing.T) {
	r := NewResolver(logger.NewNullLogger())
	result := r.ResolveSRVHttp("https://example.com")
	if result != "https://example.com" {
		t.Errorf("expected unchanged URL, got %q", result)
	}
}

func TestResolveSRVHttpPlainHost(t *testing.T) {
	r := NewResolver(logger.NewNullLogger())
	result := r.ResolveSRVHttp("example.com")
	if result != "https://example.com" {
		t.Errorf("expected https prefix added, got %q", result)
	}
}

func TestOrderSRVRecords(t *testing.T) {
	records := []SRVResult{
		{Host: "high-prio", Port: 8080, Priority: 10, Weight: 50},
		{Host: "low-prio", Port: 8080, Priority: 1, Weight: 50},
	}
	ordered := orderSRVRecords(records)
	if len(ordered) != 2 {
		t.Fatalf("expected 2 records, got %d", len(ordered))
	}
	if ordered[0].Priority != 1 {
		t.Errorf("expected lowest priority first, got priority %d", ordered[0].Priority)
	}
}

func TestLookupIP(t *testing.T) {
	r := NewResolver(logger.NewNullLogger())
	_, err := r.LookupIP("192.0.2.1")
	// This is a test-net address, lookup may fail but should not panic
	_ = err
